# GitHub OAuth App
# Create at: https://github.com/settings/developers
# Callback URL: https://app.piratedev.ai/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: https://app.piratedev.ai/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session secret (auto-read from ide-secret.txt if not set)
SESSION_SECRET=

# OAuth callback base URL
OAUTH_CALLBACK_BASE=https://app.piratedev.ai
