      "code": "cat > index.html <<'EOF'\n<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>PirateDev™ | Cloud IDE With Zero AI Markup</title>\n  <meta name=\"description\" content=\"PirateDev™ is a dark, developer-first cloud IDE with bring-your-own API keys, zero AI markup, live preview, agent mode, terminal access, and one-click deploys.\" />\n  <meta name=\"keywords\" content=\"PirateDev, cloud IDE, AI coding, zero markup AI, Monaco editor, developer tools, open core IDE\" />\n  <meta name=\"author\" content=\"Josh Stone\" />\n  <meta name=\"robots\" content=\"index, follow\" />\n  <link rel=\"canonical\" href=\"https://piratedev.dev/\" />\n\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:title\" content=\"PirateDev™ | Code Like Nobody's Watching\" />\n  <meta property=\"og:description\" content=\"A cloud IDE that passes AI costs through at zero markup. No platform tax. No vendor lock-in. Just build.\" />\n  <meta property=\"og:url\" content=\"https://piratedev.dev/\" />\n  <meta property=\"og:site_name\" content=\"PirateDev™\" />\n  <meta property=\"og:image\" content=\"https://piratedev.dev/og-image.png\" />\n\n  <meta name=\"twitter:card\" content=\"summary_large_image\" />\n  <meta name=\"twitter:title\" content=\"PirateDev™ | Zero Markup Cloud IDE\" />\n  <meta name=\"twitter:description\" content=\"Bring your own API keys. Pay actual model costs. Build in a serious cloud IDE.\" />\n  <meta name=\"twitter:image\" content=\"https://piratedev.dev/og-image.png\" />\n\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" />\n\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            pirate: {\n              black: '#0a0a0a',\n              ink: '#111111',\n              panel: '#151515',\n              line: '#2a2a2a',\n              text: '#e0e0e0',\n              muted: '#a3a3a3',\n              white: '#ffffff'\n            }\n          },\n          fontFamily: {\n            sans: ['Inter', 'system-ui', 'sans-serif'],\n            mono: ['JetBrains Mono', 'monospace']\n          },\n          keyframes: {\n            reveal: {\n              '0%': { opacity: '0', transform: 'translateY(28px)' },\n              '100%': { opacity: '1', transform: 'translateY(0)' }\n            },\n            float: {\n              '0%, 100%': { transform: 'translateY(0)' },\n              '50%': { transform: 'translateY(-10px)' }\n            }\n          },\n          animation: {\n            reveal: 'reveal 800ms ease both',\n            float: 'float 5s ease-in-out infinite'\n          }\n        }\n      }\n    }\n  </script>\n\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"SoftwareApplication\",\n    \"name\": \"PirateDev™\",\n    \"applicationCategory\": \"DeveloperApplication\",\n    \"operatingSystem\": \"Web\",\n    \"description\": \"A cloud IDE with bring-your-own AI API keys, zero markup model pricing, managed workspaces, live preview, terminal access, and deploy tools.\",\n    \"creator\": {\n      \"@type\": \"Person\",\n      \"name\": \"Josh Stone\"\n    },\n    \"offers\": [\n      { \"@type\": \"Offer\", \"name\": \"Free\", \"price\": \"0\", \"priceCurrency\": \"USD\", \"availability\": \"https://schema.org/PreOrder\" },\n      { \"@type\": \"Offer\", \"name\": \"Pro\", \"price\": \"9\", \"priceCurrency\": \"USD\", \"availability\": \"https://schema.org/PreOrder\" },\n      { \"@type\": \"Offer\", \"name\": \"Team\", \"price\": \"29\", \"priceCurrency\": \"USD\", \"availability\": \"https://schema.org/PreOrder\" }\n    ],\n    \"url\": \"https://piratedev.dev/\",\n    \"sameAs\": \"https://github.com/jstone6198/piratedev\"\n  }\n  </script>\n</head>\n<body class=\"bg-pirate-black text-pirate-text font-sans antialiased selection:bg-white selection:text-black\">\n  <header class=\"fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-pirate-black/90 backdrop-blur-xl\">\n    <nav class=\"mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-6 lg:px-8\" aria-label=\"Main navigation\">\n      <a href=\"#hero\" class=\"group flex items-center gap-3\" aria-label=\"PirateDev home\">\n        <span class=\"flex h-10 w-10 items-center justify-center rounded border border-white/20 bg-white text-lg font-black text-black transition group-hover:rotate-3\">☠</span>\n        <span class=\"font-mono text-lg font-bold tracking-tight text-white\">PirateDev™</span>\n      </a>\n      <div class=\"hidden items-center gap-8 text-sm font-semibold text-pirate-muted md:flex\">\n        <a href=\"#features\" class=\"transition hover:text-white\">Features</a>\n        <a href=\"#pricing\" class=\"transition hover:text-white\">Pricing</a>\n        <a href=\"#docs\" class=\"transition hover:text-white\">Docs</a>\n        <a href=\"https://github.com/jstone6198/piratedev\" class=\"transition hover:text-white\">GitHub</a>\n      </div>\n      <a href=\"#waitlist\" class=\"rounded border border-white bg-white px-4 py-2 text-sm font-bold text-black transition hover:bg-transparent hover:text-white\">Get Early Access</a>\n    </nav>\n  </header>\n\n  <main>\n    <section id=\"hero\" class=\"relative flex min-h-screen items-center overflow-hidden border-b border-white/10 px-5 pt-24 sm:px-6 lg:px-8\">\n      <div class=\"absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:56px_56px] opacity-20\"></div>\n      <div class=\"absolute bottom-0 left-0 right-0 h-56 bg-gradient-to-t from-pirate-black to-transparent\"></div>\n      <div class=\"relative mx-auto grid max-w-7xl items-center gap-12 py-16 lg:grid-cols-[1.08fr_0.92fr]\">\n        <div class=\"animate-reveal\">\n          <p class=\"mb-5 inline-flex rounded border border-white/20 px-3 py-1 font-mono text-xs font-bold uppercase tracking-widest text-white\">BYO keys. Keep the loot.</p>\n          <h1 class=\"max-w-5xl text-5xl font-black leading-[0.95] tracking-tight text-white sm:text-6xl lg:text-8xl\">Code Like Nobody's Watching. Deploy Like Everyone Is.</h1>\n          <p class=\"mt-7 max-w-2xl text-lg leading-8 text-pirate-muted sm:text-xl\">A cloud IDE that passes AI costs through at zero markup. No platform tax. No vendor lock-in. Just build.</p>\n          <div class=\"mt-10 flex flex-col gap-4 sm:flex-row\">\n            <a href=\"#waitlist\" class=\"rounded bg-white px-6 py-4 text-center font-bold text-black transition hover:bg-pirate-text\">Get Early Access</a>\n            <a href=\"https://github.com/jstone6198/piratedev\" class=\"rounded border border-white/30 px-6 py-4 text-center font-bold text-white transition hover:border-white hover:bg-white hover:text-black\">View on GitHub</a>\n          </div>\n        </div>\n        <div class=\"animate-float rounded border border-white/15 bg-pirate-panel shadow-2xl shadow-black/60\">\n          <div class=\"flex items-center gap-2 border-b border-white/10 px-4 py-3\">\n            <span class=\"h-3 w-3 rounded-full bg-white/30\"></span>\n            <span class=\"h-3 w-3 rounded-full bg-white/50\"></span>\n            <span class=\"h-3 w-3 rounded-full bg-white\"></span>\n            <span class=\"ml-3 font-mono text-xs text-pirate-muted\">piratedev/workspace</span>\n          </div>\n          <pre class=\"overflow-hidden p-5 font-mono text-sm leading-7 text-pirate-text\"><code><span class=\"text-white\">const</span> platformTax = 0;\n<span class=\"text-white\">const</span> apiKey = process.env.YOUR_KEY;\n\nagent.run({\n  task: <span class=\"text-white\">\"ship the feature\"</span>,\n  model: <span class=\"text-white\">\"your choice\"</span>,\n  markup: <span class=\"text-white\">\"absolutely not\"</span>\n});\n\n<span class=\"text-pirate-muted\">// deploy to your VPS</span>\n$ piratedev deploy --target prod</code></pre>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"problem\" class=\"border-b border-white/10 px-5 py-24 sm:px-6 lg:px-8\">\n      <div class=\"mx-auto max-w-7xl\">\n        <p class=\"font-mono text-sm font-bold uppercase tracking-widest text-pirate-muted\">The problem</p>\n        <h2 class=\"mt-4 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-5xl\">Every Cloud IDE Takes a Cut.</h2>\n        <div class=\"mt-12 grid gap-5 md:grid-cols-3\">\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\">\n            <h3 class=\"text-xl font-bold text-white\">Replit</h3>\n            <p class=\"mt-4 text-pirate-muted\">AI requests can land at 10-20x the raw model cost. Convenient, expensive, predictable.</p>\n          </article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\">\n            <h3 class=\"text-xl font-bold text-white\">Codespaces</h3>\n            <p class=\"mt-4 text-pirate-muted\">Strong workspaces, tight Azure gravity. Great if that is already your ocean.</p>\n          </article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\">\n            <h3 class=\"text-xl font-bold text-white\">Cursor</h3>\n            <p class=\"mt-4 text-pirate-muted\">$20/month for model access you could hit directly at API cost.</p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"solution\" class=\"border-b border-white/10 px-5 py-24 sm:px-6 lg:px-8\">\n      <div class=\"mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center\">\n        <div>\n          <p class=\"font-mono text-sm font-bold uppercase tracking-widest text-pirate-muted\">The solution</p>\n          <h2 class=\"mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl\">Zero Markup. Zero Apologies.</h2>\n          <p class=\"mt-6 text-lg leading-8 text-pirate-muted\">Bring your own API keys for Claude, OpenAI, Groq, or whatever earns a spot in your stack. PirateDev passes model costs through at $0 markup. You pay for compute, not somebody else's margin experiment.</p>\n        </div>\n        <div class=\"overflow-hidden rounded border border-white/15 bg-pirate-panel\">\n          <div class=\"grid grid-cols-3 border-b border-white/10 bg-white text-sm font-black text-black\">\n            <div class=\"p-4\">Model Use</div>\n            <div class=\"p-4\">Typical Tool</div>\n            <div class=\"p-4\">PirateDev</div>\n          </div>\n          <div class=\"grid grid-cols-3 border-b border-white/10 font-mono text-sm\">\n            <div class=\"p-4 text-white\">GPT-4o request</div>\n            <div class=\"p-4 text-pirate-muted\">~$0.15/request</div>\n            <div class=\"p-4 text-white\">~$0.01/request</div>\n          </div>\n          <div class=\"grid grid-cols-3 border-b border-white/10 font-mono text-sm\">\n            <div class=\"p-4 text-white\">Claude request</div>\n            <div class=\"p-4 text-pirate-muted\">Bundled markup</div>\n            <div class=\"p-4 text-white\">Actual API cost</div>\n          </div>\n          <div class=\"grid grid-cols-3 font-mono text-sm\">\n            <div class=\"p-4 text-white\">Platform tax</div>\n            <div class=\"p-4 text-pirate-muted\">Always lurking</div>\n            <div class=\"p-4 text-white\">$0</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"features\" class=\"border-b border-white/10 px-5 py-24 sm:px-6 lg:px-8\">\n      <div class=\"mx-auto max-w-7xl\">\n        <p class=\"font-mono text-sm font-bold uppercase tracking-widest text-pirate-muted\">Features</p>\n        <h2 class=\"mt-4 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-5xl\">Everything you need. Nothing wearing a suit.</h2>\n        <div class=\"mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3\">\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\"><div class=\"text-3xl\">⌨️</div><h3 class=\"mt-5 text-xl font-bold text-white\">Code Editor</h3><p class=\"mt-3 text-pirate-muted\">Monaco-based, dark theme, every language worth opening.</p></article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\"><div class=\"text-3xl\">🧠</div><h3 class=\"mt-5 text-xl font-bold text-white\">AI Chat</h3><p class=\"mt-3 text-pirate-muted\">Claude, GPT, Groq. Your keys, your choice, your bill.</p></article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\"><div class=\"text-3xl\">⚙️</div><h3 class=\"mt-5 text-xl font-bold text-white\">Agent Mode</h3><p class=\"mt-3 text-pirate-muted\">Describe what you want. The AI builds it step by step.</p></article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\"><div class=\"text-3xl\">🔥</div><h3 class=\"mt-5 text-xl font-bold text-white\">Live Preview</h3><p class=\"mt-3 text-pirate-muted\">See changes instantly with hot reload that keeps up.</p></article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\"><div class=\"text-3xl\">🚀</div><h3 class=\"mt-5 text-xl font-bold text-white\">One-Click Deploy</h3><p class=\"mt-3 text-pirate-muted\">Deploy to your own VPS, not our servers.</p></article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6 transition hover:-translate-y-1 hover:border-white/30\"><div class=\"text-3xl\">💀</div><h3 class=\"mt-5 text-xl font-bold text-white\">Built-in Terminal</h3><p class=\"mt-3 text-pirate-muted\">Full shell access. Run anything. Own the box.</p></article>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"docs\" class=\"border-b border-white/10 px-5 py-24 sm:px-6 lg:px-8\">\n      <div class=\"mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center\">\n        <div>\n          <p class=\"font-mono text-sm font-bold uppercase tracking-widest text-pirate-muted\">Open source</p>\n          <h2 class=\"mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl\">Open Core. Open Rebellion.</h2>\n          <p class=\"mt-6 text-lg leading-8 text-pirate-muted\">AGPL frontend. Proprietary backend. See exactly what you're running. Fork it. Improve it. Just don't charge for it without a license.</p>\n          <a href=\"https://github.com/jstone6198/piratedev\" class=\"mt-8 inline-flex rounded border border-white/30 px-6 py-4 font-bold text-white transition hover:border-white hover:bg-white hover:text-black\">Read the code</a>\n        </div>\n        <div class=\"rounded border border-white/15 bg-pirate-panel p-6 font-mono text-sm text-pirate-muted\">\n          <p class=\"text-white\">license.md</p>\n          <p class=\"mt-4\">frontend: AGPL</p>\n          <p>backend: commercial</p>\n          <p>status: rebellion compiling</p>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"pricing\" class=\"border-b border-white/10 px-5 py-24 sm:px-6 lg:px-8\">\n      <div class=\"mx-auto max-w-7xl\">\n        <p class=\"font-mono text-sm font-bold uppercase tracking-widest text-pirate-muted\">Pricing</p>\n        <h2 class=\"mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl\">Pay for the IDE. Not the ransom.</h2>\n        <div class=\"mt-12 grid gap-5 lg:grid-cols-3\">\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6\"><p class=\"font-mono text-xs font-bold uppercase tracking-widest text-pirate-muted\">Coming Soon</p><h3 class=\"mt-4 text-2xl font-black text-white\">Free</h3><p class=\"mt-3 text-4xl font-black text-white\">$0</p><p class=\"mt-5 text-pirate-muted\">Self-host, bring your own infra, community support.</p><a href=\"#waitlist\" class=\"mt-8 block rounded border border-white/30 px-5 py-3 text-center font-bold text-white transition hover:bg-white hover:text-black\">Join waitlist</a></article>\n          <article class=\"rounded border border-white bg-pirate-panel p-6\"><p class=\"font-mono text-xs font-bold uppercase tracking-widest text-white\">Coming Soon</p><h3 class=\"mt-4 text-2xl font-black text-white\">Pro</h3><p class=\"mt-3 text-4xl font-black text-white\">$9<span class=\"text-lg text-pirate-muted\">/mo</span></p><p class=\"mt-5 text-pirate-muted\">Hosted IDE, managed VPS, priority support.</p><a href=\"#waitlist\" class=\"mt-8 block rounded bg-white px-5 py-3 text-center font-bold text-black transition hover:bg-pirate-text\">Join waitlist</a></article>\n          <article class=\"rounded border border-white/10 bg-pirate-panel p-6\"><p class=\"font-mono text-xs font-bold uppercase tracking-widest text-pirate-muted\">Coming Soon</p><h3 class=\"mt-4 text-2xl font-black text-white\">Team</h3><p class=\"mt-3 text-4xl font-black text-white\">$29<span class=\"text-lg text-pirate-muted\">/seat/mo</span></p><p class=\"mt-5 text-pirate-muted\">Shared workspaces, team secrets, admin controls.</p><a href=\"#waitlist\" class=\"mt-8 block rounded border border-white/30 px-5 py-3 text-center font-bold text-white transition hover:bg-white hover:text-black\">Join waitlist</a></article>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"waitlist\" class=\"px-5 py-24 sm:px-6 lg:px-8\">\n      <div class=\"mx-auto max-w-4xl text-center\">\n        <h2 class=\"text-4xl font-black tracking-tight text-white sm:text-6xl\">Stop Paying the Platform Tax.</h2>\n        <p class=\"mx-auto mt-6 max-w-2xl text-lg text-pirate-muted\">Get early access when the ship leaves port.</p>\n        <form class=\"mx-auto mt-10 flex max-w-xl flex-col gap-3 sm:flex-row\" action=\"#\" method=\"post\">\n          <label class=\"sr-only\" for=\"email\">Email address</label>\n          <input id=\"email\" name=\"email\" type=\"email\" required placeholder=\"you@example.com\" class=\"min-h-14 flex-1 rounded border border-white/20 bg-pirate-panel px-4 font-mono text-white outline-none transition placeholder:text-pirate-muted focus:border-white\" />\n          <button type=\"submit\" class=\"min-h-14 rounded bg-white px-6 font-bold text-black transition hover:bg-pirate-text\">Get Early Access</button>\n        </form>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"border-t border-white/10 px-5 py-10 sm:px-6 lg:px-8\">\n    <div class=\"mx-auto flex max-w-7xl flex-col gap-6 md:flex-row md:items-center md:justify-between\">\n      <div>\n        <p class=\"font-mono font-bold text-white\">PirateDev™ © 2026 Josh Stone.</p>\n        <p class=\"mt-2 text-sm text-pirate-muted\">Built with PirateDev™</p>\n      </div>\n      <div class=\"flex flex-wrap gap-5 text-sm font-semibold text-pirate-muted\">\n        <a href=\"https://github.com/jstone6198/piratedev\" class=\"transition hover:text-white\">GitHub</a>\n        <a href=\"#docs\" class=\"transition hover:text-white\">Docs</a>\n        <a href=\"#docs\" class=\"transition hover:text-white\">License</a>\n        <a href=\"mailto:josh@piratedev.dev\" class=\"transition hover:text-white\">Contact</a>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\nEOF",
